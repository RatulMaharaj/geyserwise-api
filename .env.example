# Geyserwise Device Configuration
GEYSERWISE_DEVICE_ID=your_device_id
GEYSERWISE_LOCAL_KEY=your_local_key
GEYSERWISE_IP=192.168.1.x
GEYSERWISE_VERSION=3.4

# API Server Port
GEYSERWISE_API_PORT=8099

# Homebridge Webhook Integration
HOMEBRIDGE_WEBHOOK_URL=http://localhost:51830
SYNC_INTERVAL_SECONDS=30
